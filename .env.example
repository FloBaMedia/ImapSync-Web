# PostgreSQL password (do NOT use "changeme" in production)
DB_PASSWORD=changeme

# Secret for signing session JWTs — minimum 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=

# AES-256-GCM key for encrypting IMAP passwords at rest — must be 64 hex chars (32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Initial admin login (created on first boot)
# Password must be at least 8 characters and not "admin"/"password"
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=

# Public port for the web UI (default 3000)
PORT=3000

# Runner tuning (optional)
# POLL_INTERVAL_MS=1000
# MAX_PARALLEL=50
