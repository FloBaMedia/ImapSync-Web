# Datenbank-Passwort für PostgreSQL
DB_PASSWORD=changeme

# JWT-Secret für Sessions (mindestens 32 Zeichen)
JWT_SECRET=change-this-jwt-secret-in-production-min-32-chars

# Verschlüsselungsschlüssel für IMAP-Passwörter (64 Hex-Zeichen = 32 Bytes)
# Generieren mit: openssl rand -hex 32
ENCRYPTION_KEY=a1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60718293a4b5c6d7e8f9

# Admin-Login für die Web-UI
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# Port der Web-UI (Standard: 3000)
PORT=3000
